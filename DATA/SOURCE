## Preferred starter source after variant testing:
## a shallow Mxz shear couple 10 m below the free surface.
## This keeps much more shear/Rayleigh character than the isotropic opening
## moment tensor or the free-surface point-force sources tested here.
source_surf                     = .false.
xs                              = -10000.d0
zs                              = 1490.d0

## Moment tensor source
source_type                     = 2
time_function_type              = 1
name_of_source_file             = UNUSED
burst_band_width                = 0.
f0                              = 10.0d0
tshift                          = 0.0d0
anglesource                     = 0.0d0

## Pure Mxz shear couple in 2D P-SV
Mxx                             = 0.d0
Mzz                             = 0.d0
Mxz                             = 1.d0

factor                          = 2.d10
vx                              = 0.0d0
vz                              = 0.0d0
